# ============ DATABASE ============
DATABASE_URL="postgresql://buildbrain:buildbrain_dev_password@localhost:5432/buildbrain_db"
MONGODB_URI="mongodb://buildbrain:buildbrain_dev_password@localhost:27017/buildbrain_db"
REDIS_URL="redis://localhost:6379"

# ============ AI & VECTOR DB ============
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY="buildbrain_qdrant_key"

# ============ STORAGE (MinIO S3) ============
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="buildbrain"
S3_SECRET_KEY="buildbrain_dev_password"
S3_BUCKET_NAME="buildbrain-files"
S3_REGION="us-east-1"

# ============ MESSAGE QUEUE ============
RABBITMQ_URL="amqp://buildbrain:buildbrain_dev_password@localhost:5672"
KAFKA_BROKERS="localhost:9092"  # Optional: Use Kafka instead of RabbitMQ
KAFKA_TOPIC_PAYMENTS="payments"
KAFKA_TOPIC_NOTIFICATIONS="notifications"

# ============ AUTH & JWT ============
JWT_SECRET="your_jwt_secret_key_change_this_in_production"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your_refresh_token_secret_change_this"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ============ API KEYS ============
NODE_ENV="development"
API_PORT="4000"
API_URL="http://localhost:4000"
WEB_URL="http://localhost:3000"

# ============ STRIPE (Payment Processing) ============
STRIPE_SECRET_KEY="sk_test_xxxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxx"

# ============ DWOLLA (ACH) ============
DWOLLA_CLIENT_ID="xxxxx"
DWOLLA_CLIENT_SECRET="xxxxx"
DWOLLA_ENVIRONMENT="sandbox"  # or "production"

# ============ PLAID (Bank Verification) ============
PLAID_CLIENT_ID="xxxxx"
PLAID_SECRET="xxxxx"
PLAID_ENVIRONMENT="sandbox"

# ============ UNIT (Banking-as-a-Service) ============
UNIT_API_KEY="xxxxx"
UNIT_ENVIRONMENT="sandbox"

# ============ KYC/AML PROVIDERS ============
# Persona
PERSONA_INQUIRY_TEMPLATE_ID="xxxxx"
PERSONA_API_KEY="xxxxx"

# SumSub
SUMSUBID="xxxxx"
SUMSUBID_SECRET_KEY="xxxxx"

# Middesk (Business Verification)
MIDDESK_API_KEY="xxxxx"

# ============ LLM & AI SERVICES ============
# OpenAI (Fallback LLM)
OPENAI_API_KEY="sk-xxxxx"
OPENAI_ORG_ID="org-xxxxx"

# Ollama (Self-hosted LLM)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama2:7b"  # or larger model

# Anthropic Claude (Alternative)
ANTHROPIC_API_KEY="sk-ant-xxxxx"

# LangChain Settings
LANGCHAIN_API_KEY="xxxxx"
LANGCHAIN_TRACING_V2="true"

# ============ DOCUMENT PROCESSING ============
# AWS Textract (Fallback OCR)
AWS_ACCESS_KEY_ID="xxxxx"
AWS_SECRET_ACCESS_KEY="xxxxx"
AWS_REGION="us-east-1"

# Unstructured IO (PDF parsing)
UNSTRUCTURED_API_KEY="xxxxx"

# ============ GEOLOCATION & MAPPING ============
MAPBOX_ACCESS_TOKEN="pk_xxxxx"
GOOGLE_MAPS_API_KEY="xxxxx"

# ============ COMMUNICATION ============
# Twilio (SMS)
TWILIO_ACCOUNT_SID="xxxxx"
TWILIO_AUTH_TOKEN="xxxxx"
TWILIO_PHONE_NUMBER="+1234567890"

# SendGrid (Email)
SENDGRID_API_KEY="SG_xxxxx"
SENDGRID_FROM_EMAIL="noreply@buildbrain.io"

# Firebase (Push notifications)
FIREBASE_PROJECT_ID="xxxxx"
FIREBASE_PRIVATE_KEY="xxxxx"
FIREBASE_CLIENT_EMAIL="xxxxx"

# ============ EXTERNAL INTEGRATIONS ============
# Procore
PROCORE_CLIENT_ID="xxxxx"
PROCORE_CLIENT_SECRET="xxxxx"

# Autodesk BIM 360
AUTODESK_CLIENT_ID="xxxxx"
AUTODESK_CLIENT_SECRET="xxxxx"

# DocuSign
DOCUSIGN_INTEGRATION_KEY="xxxxx"
DOCUSIGN_SECRET="xxxxx"

# SAM.gov (Government Procurement)
SAMGOV_API_KEY="xxxxx"

# ============ LOGGING & MONITORING ============
LOG_LEVEL="debug"  # "error", "warn", "info", "debug"
SENTRY_DSN="https://xxxxx@sentry.io/xxxxx"
DATADOG_API_KEY="xxxxx"

# ============ ANALYTICS ============
MIXPANEL_TOKEN="xxxxx"
AMPLITUDE_API_KEY="xxxxx"

# ============ SECURITY ============
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"
RATE_LIMIT_WINDOW_MS="900000"  # 15 minutes
RATE_LIMIT_MAX_REQUESTS="100"

# ============ ADMIN & INTERNAL ============
ADMIN_EMAIL="admin@buildbrain.io"
SUPPORT_EMAIL="support@buildbrain.io"
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxxxx"

# ============ FEATURE FLAGS ============
ENABLE_CRYPTO_PAYMENTS="false"  # Use USDC later
ENABLE_GOVERNMENT_PROCUREMENT="true"
ENABLE_AI_AGENTS="true"
ENABLE_LIEN_WAIVERS="true"
ENABLE_PERMIT_AUTOMATION="true"

# ============ PAYMENT SETTINGS ============
PAYMENTFAC_MODE="true"  # Use PayFac partners instead of direct MSB license
DEFAULT_PAYMENT_METHOD="ACH"
ESCROW_PROVIDER="stripe"  # "stripe" or "unit"
FLOAT_INTEREST_RATE="0.05"  # 5% annual interest on float

# ============ DEPLOYMENT ============
ENVIRONMENT="development"  # "development", "staging", "production"
VERSION="0.1.0"
